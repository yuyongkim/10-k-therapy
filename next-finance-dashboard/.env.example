# 10-k-therapy — Next.js frontend environment
# Copy to .env.local and adjust. Do NOT commit .env.local.

# Public API URL used by the browser. Defaults to the /fastapi/* rewrite in
# next.config.ts which proxies to BACKEND_URL. Change to a direct URL
# (e.g. http://localhost:8000/api) if you disable the proxy.
NEXT_PUBLIC_API_URL=/fastapi/api

# Internal backend URL used by the Next.js rewrite target and server-only code.
BACKEND_URL=http://localhost:8000
