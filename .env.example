# API keys
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COURTLISTENER_API_KEY=your_courtlistener_api_key
DART_API_KEY=your_dart_api_key
OLLAMA_BASE_URL=http://localhost:11434

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=license_db
DB_USER=postgres
DB_PASSWORD=your_db_password

# Path standardization
PROJECT_ROOT=.
DATA_DIR=./data

# Example external root (change for your machine)
EXTERNAL_DATA_ROOT=G:/SEC/sec-license-extraction-data
RAW_FILINGS_DIR=${EXTERNAL_DATA_ROOT}/raw_filings
PARSED_CONTRACTS_DIR=${EXTERNAL_DATA_ROOT}/parsed_contracts

# Optional local outputs
EXPORTS_DIR=${DATA_DIR}/exports
DART_RAW_DIR=${DATA_DIR}/dart/raw_filings
DART_SCHEMA_DIR=${DATA_DIR}/dart/unified_schema
LOG_DIR=./logs

# Optional notifications
SLACK_WEBHOOK_URL=
EMAIL_SMTP_SERVER=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
