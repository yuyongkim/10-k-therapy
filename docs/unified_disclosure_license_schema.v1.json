{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sec-license-extraction.local/schema/unified_disclosure_license_schema.v1.json",
  "title": "Unified Disclosure + License Schema v1",
  "description": "Unified schema for SEC/DART filings with section intelligence and optional structured license agreement extraction.",
  "type": "object",
  "required": [
    "schema_version",
    "document_id",
    "source_info",
    "company",
    "processing_info",
    "sections"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "unified_disclosure_license.v1"
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "source_info": {
      "type": "object",
      "required": [
        "system"
      ],
      "properties": {
        "system": {
          "type": "string",
          "enum": [
            "SEC",
            "DART"
          ]
        },
        "document_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "filing_date": {
          "type": [
            "string",
            "null"
          ]
        },
        "period_end": {
          "type": [
            "string",
            "null"
          ]
        },
        "language": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "company": {
      "type": "object",
      "required": [
        "name",
        "identifier"
      ],
      "properties": {
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "identifier": {
          "type": "string",
          "minLength": 1
        },
        "ticker": {
          "type": [
            "string",
            "null"
          ]
        },
        "industry": {
          "type": [
            "string",
            "null"
          ]
        },
        "country": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "processing_info": {
      "type": "object",
      "required": [
        "ingestion_date",
        "parser_version",
        "status"
      ],
      "properties": {
        "ingestion_date": {
          "type": "string"
        },
        "parser_version": {
          "type": "string"
        },
        "total_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "status": {
          "type": "string",
          "enum": [
            "parsed",
            "enriched",
            "failed"
          ]
        }
      },
      "additionalProperties": true
    },
    "document_metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "entity_profile": {
      "type": "object",
      "additionalProperties": true
    },
    "xbrl_summary": {
      "type": "object",
      "properties": {
        "key_metrics": {
          "type": "object",
          "additionalProperties": true
        },
        "metric_history": {
          "type": "object",
          "additionalProperties": true
        },
        "context_summary": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "document_intelligence": {
      "type": "object",
      "properties": {
        "section_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "total_sections": {
          "type": "integer",
          "minimum": 0
        },
        "sections_with_tables": {
          "type": "integer",
          "minimum": 0
        },
        "financial_signal_sections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "detected_currencies": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "risk_keyword_signal": {
          "type": "integer",
          "minimum": 0
        },
        "core_mapping_completeness": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": true
    },
    "sections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/section"
      }
    },
    "license_candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/licenseCandidate"
      }
    },
    "agreements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/licenseAgreement"
      }
    },
    "agreement_summary": {
      "$ref": "#/$defs/licenseCostSummary"
    },
    "lineage": {
      "$ref": "#/$defs/lineage"
    }
  },
  "additionalProperties": true,
  "$defs": {
    "section": {
      "type": "object",
      "required": [
        "section_id",
        "section_mapping",
        "content",
        "extracted_insights"
      ],
      "properties": {
        "section_id": {
          "type": "string"
        },
        "section_mapping": {
          "type": "object",
          "required": [
            "common_tag",
            "sec_label",
            "dart_label",
            "order_index"
          ],
          "properties": {
            "common_tag": {
              "type": "string",
              "enum": [
                "business_overview",
                "risk_factors",
                "mdna",
                "financials",
                "legal_proceedings",
                "governance",
                "major_events",
                "other_disclosures"
              ]
            },
            "sec_label": {
              "type": "string"
            },
            "dart_label": {
              "type": "string"
            },
            "dart_eng_label": {
              "type": [
                "string",
                "null"
              ]
            },
            "order_index": {
              "type": "integer",
              "minimum": 1
            }
          },
          "additionalProperties": true
        },
        "content": {
          "type": "object",
          "required": [
            "raw_html",
            "plain_text",
            "token_count",
            "has_tables",
            "has_financial_data"
          ],
          "properties": {
            "raw_html": {
              "type": "string"
            },
            "plain_text": {
              "type": "string"
            },
            "token_count": {
              "type": "integer",
              "minimum": 0
            },
            "has_tables": {
              "type": "boolean"
            },
            "has_financial_data": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        },
        "extracted_insights": {
          "type": "object",
          "properties": {
            "license_costs": {
              "$ref": "#/$defs/licenseCostSummary"
            },
            "key_business_areas": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "competitive_advantages": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "regulatory_concerns": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "quantitative_profile": {
              "type": "object",
              "properties": {
                "money_mentions_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "percent_mentions_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "year_mentions_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "currency_codes": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "money_examples": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "percent_examples": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "year_examples": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": true
            },
            "topic_keyword_counts": {
              "type": "object",
              "additionalProperties": {
                "type": "integer",
                "minimum": 0
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "licenseCandidate": {
      "type": "object",
      "properties": {
        "note_number": {
          "type": [
            "string",
            "null"
          ]
        },
        "note_title": {
          "type": [
            "string",
            "null"
          ]
        },
        "content": {
          "type": "string"
        },
        "relevance_score": {
          "type": [
            "number",
            "null"
          ]
        },
        "matched_keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "matched_companies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "licenseAgreement": {
      "type": "object",
      "required": [
        "parties",
        "technology",
        "financial_terms",
        "contract_terms",
        "metadata"
      ],
      "properties": {
        "agreement_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_section_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_note_number": {
          "type": [
            "string",
            "null"
          ]
        },
        "industry": {
          "type": [
            "string",
            "null"
          ]
        },
        "parties": {
          "type": "object",
          "properties": {
            "licensor": {
              "type": "object",
              "properties": {
                "name": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "role": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "additionalProperties": true
            },
            "licensee": {
              "type": "object",
              "properties": {
                "name": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "role": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "technology": {
          "type": "object",
          "properties": {
            "name": {
              "type": [
                "string",
                "null"
              ]
            },
            "category": {
              "type": [
                "string",
                "null"
              ]
            },
            "capacity": {
              "type": "object",
              "properties": {
                "value": {
                  "type": [
                    "number",
                    "string",
                    "null"
                  ]
                },
                "unit": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "financial_terms": {
          "type": "object",
          "properties": {
            "upfront_payment": {
              "type": "object",
              "properties": {
                "amount": {
                  "type": [
                    "number",
                    "string",
                    "null"
                  ]
                },
                "currency": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "additionalProperties": true
            },
            "royalty": {
              "type": "object",
              "properties": {
                "rate": {
                  "type": [
                    "number",
                    "string",
                    "null"
                  ]
                },
                "unit": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "contract_terms": {
          "type": "object",
          "properties": {
            "term": {
              "type": "object",
              "properties": {
                "years": {
                  "type": [
                    "number",
                    "string",
                    "null"
                  ]
                }
              },
              "additionalProperties": true
            },
            "territory": {
              "type": "object",
              "properties": {
                "geographic": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "metadata": {
          "type": "object",
          "properties": {
            "confidence_score": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0,
              "maximum": 1
            },
            "extraction_reasoning": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": true
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source_section_id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "source_note_number": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "quote": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "char_start": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0
              },
              "char_end": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "licenseCostSummary": {
      "type": "object",
      "properties": {
        "total_annual_cost": {
          "type": [
            "number",
            "null"
          ]
        },
        "currency": {
          "type": [
            "string",
            "null"
          ]
        },
        "major_licenses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "licensor": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "cost": {
                "type": [
                  "number",
                  "null"
                ]
              },
              "type": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "contract_period": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": true
          }
        },
        "analysis_confidence": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "source_location": {
          "type": [
            "string",
            "null"
          ]
        },
        "total_agreements": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "lineage": {
      "type": "object",
      "properties": {
        "run_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "input_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "llm": {
          "type": "object",
          "properties": {
            "provider": {
              "type": [
                "string",
                "null"
              ]
            },
            "model": {
              "type": [
                "string",
                "null"
              ]
            },
            "temperature": {
              "type": [
                "number",
                "null"
              ]
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  }
}
